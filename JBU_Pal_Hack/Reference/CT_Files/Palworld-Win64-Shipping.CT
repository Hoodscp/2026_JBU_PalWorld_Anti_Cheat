local baseAddress = getAddress('healthWhenAttackedSaveSpace')
local size = 0x50


for i = 0, size - 1 do
    writeBytes(baseAddress + i, 0)
end
for i = 0, 3 do
    writeBytes(baseAddress - 12, 0)
end
{$asm}

{$lua}
if syntaxcheck then return end

local t=createTimer()
t.Interval=50
t.OnTimer=function()
  memrec.Active=false
  t.destroy()
end
