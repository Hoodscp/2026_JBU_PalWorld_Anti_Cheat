    <CheatEntry>
      <ID>26286</ID>
      <Description>"Get Item On Hover"</Description>
      <Options moHideChildren="1"/>
      <LastState/>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>{ Game   : Palworld-Win64-Shipping.exe
  Version: 
  Date   : Probably somewhen, considering it exists
  Author : Byakuran

  This script injects code at the selected area
}
[ENABLE]

{$LUA}
if memrec then
  if memrec.Active then
    memrec.Active=false
  end
end

local moduleName = "Palworld-Win64-Shipping.exe"
local pattern = "4C 03 C8 4C 89 4A 20 8B 81 54 01 00 00 41 89 00 C3 CC"
local name = "getItemOnHover"
local targetIndex = 1
local many = false

-- Run setup
setupPattern(pattern, name, targetIndex, moduleName, many)
{$asm}
//aobscanmodule(getItemOnHover, Palworld-Win64-Shipping.exe, 8B 81 54 01 00 00)
alloc(newmem0,$1000,getItemOnHover)
label(code0)
label(return0)

label(getItemOnHoverSaveSpace)
registersymbol(getItemOnHoverSaveSpace)
label(itemCounter)
label(cleanup)
label(checkIfExists)

newmem0:
           
push rax
push rbx
push rdx
push rsi

mov eax,[itemCounter]
lea rbx,[rcx+154]
lea rdx,[getItemOnHoverSaveSpace]

xor esi,esi  // Initialize counter
checkIfExists:
cmp [rdx+rsi*8],rbx
je cleanup
inc esi
cmp esi,eax
jl checkIfExists

addToArray:
mov [rdx+rax*8],rbx
inc [itemCounter]
cmp [itemCounter],#10
jb cleanup
mov [itemCounter],#0

cleanup:
pop rsi
pop rdx
pop rbx
pop rax

code0:
  mov eax,[rcx+00000154]
  jmp return0
 
itemCounter:
dd 0

getItemOnHoverSaveSpace:
dq 0

getItemOnHover+7:
  jmp newmem0
  nop 1
return0:

[DISABLE]

getItemOnHover+7:
  db 8B 81 54 01 00 00

unregistersymbol(getItemOnHover)
unregistersymbol(*)
dealloc(newmem0)


