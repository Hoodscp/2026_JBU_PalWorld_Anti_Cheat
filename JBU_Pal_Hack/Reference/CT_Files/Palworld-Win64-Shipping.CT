  <Comments>Info about this table:
</Comments>
  <LuaScript>-- Auto-generated script to execute table files
local function executeTableFiles()
    local filesToExecute = {
        "header_vars",
        "visual_functions",
        "notification_functions",
        "scanning_functions",
        "util_functions",
        "setup_table"
    }

    -- print("Executing table files...")
    for _, filename in ipairs(filesToExecute) do
        local file = findTableFile(filename)
        if file then
            local stream = file.Stream
            stream.Position = 0
            local content = ""
            
            -- Read all bytes from stream
            while stream.Position &lt; stream.Size do
                content = content .. string.char(stream.ReadByte())
            end
            
            -- print("Executing table file: " .. filename .. " (" .. tostring(string.len(content)) .. " bytes)")
            
            local success, err = pcall(function()
                local func, loadErr = load(content, filename)
                if not func then
                    error("Failed to load " .. filename .. ": " .. tostring(loadErr))
                end
                func()
            end)
            
            if not success then
                print("ERROR executing " .. filename .. ": " .. tostring(err))
            else
               -- print("Successfully executed: " .. filename)
            end
        else
            print("Table file not found: " .. filename)
        end
    end
    -- print("Finished executing table files")
end

-- Execute on table load
executeTableFiles()

-- refresh files
-- createStandardFiles()
</LuaScript>
</CheatTable>
