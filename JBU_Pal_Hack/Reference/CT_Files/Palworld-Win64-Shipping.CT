                <CheatEntry>
                  <ID>1077</ID>
                  <Description>"Gets Health Of Attacked and others"</Description>
                  <Options moHideChildren="1" moDeactivateChildrenAsWell="1"/>
                  <LastState/>
                  <Color>0000FF</Color>
                  <VariableType>Auto Assembler Script</VariableType>
                  <AssemblerScript>{ Game   : Palworld-Win64-Shipping.exe
  Version: 
  Date   : 2024-12-26
  Author : krebs

  This script does blah blah blah
}

[ENABLE]
{$lua}

if memrec.Active then
   memrec.Active=false
end

local moduleName = "Palworld-Win64-Shipping.exe"
local pattern = "EF FE FF 48 8B 93 78 03 00 00"
local name = "healthWhenAttacked"
local targetIndex = 1
local many = false

-- Run setup
setupPattern(pattern, name, targetIndex, moduleName, many)

{$asm}
//aobscanmodule(healthWhenAttacked,Palworld-Win64-Shipping.exe,EF FE FF 48 8B 93 78 03 00 00) // should be unique
alloc(newmem,$1000,healthWhenAttacked)

label(code)
label(return)

label(healthWhenAttackedSaveSpace)
registersymbol(healthWhenAttackedSaveSpace)

label(playerHPPtr)
registersymbol(playerHPPtr)

label(itemCounter)
label(cleanup)
label(checkIfExists)

label(removeAndShift)
label(shiftLoop)

label(nonPlayer)

label(array)

label(OHKenemies)

label(OHKenable)
registersymbol(OHKenable)

newmem:

cmp [rbx+00000340],23741FA0
jb nonPlayer

push rax
lea rax,[rbx+00000378]
mov [playerHPPtr],rax
pop rax
jmp code

nonPlayer:
push rax
push rcx
push rdx
push rsi
push rdi

array:
mov eax,[itemCounter]
lea rcx,[rbx+00000378]
lea rdx,[healthWhenAttackedSaveSpace]
xor esi,esi

checkIfExists:
cmp [rdx+rsi*8],rcx
je OHKenemies
inc esi
cmp esi,eax
jl checkIfExists

removeAndShift:
xor esi,esi
shiftLoop:
cmp esi,[itemCounter]
jge addToArray
mov rdi,[rdx+rsi*8]
test rdi,rdi
jle shift_elements
inc esi
jmp shiftLoop

shift_elements:
push rsi
mov rdi,rsi
inc rdi
shift_next:
cmp rdi,[itemCounter]
jge shift_done
mov rax,[rdx+rdi*8]
mov [rdx+rsi*8],rax
inc rdi
inc rsi
jmp shift_next
shift_done:
pop rsi
dec [itemCounter]
jmp shiftLoop

addToArray:
mov [rdx+rax*8],rcx
inc [itemCounter]
cmp [itemCounter],#10
jb cleanup
mov [itemCounter],#0
jmp cleanup

OHKenemies:
cmp byte ptr [OHKenable],1
jne cleanup
/*
offset allyPal enemyPal reliable?
314    0       3        no
DCC    0       notZero  no
-------------------
60     1       0
64     4       0
260    1       0
3D8    1       0
3DC    1       0
5A4    1       0
*/
cmp [rbx+60],0
jne cleanup
mov [rbx+00000378],0

cleanup:
pop rdi
pop rsi
pop rdx
pop rcx
pop rax

code:
  mov rdx,[rbx+00000378]
  jmp return

OHKenable:
db 0

itemCounter:
dd 0

playerHPPtr:
dq 0

healthWhenAttackedSaveSpace:
dq 0

healthWhenAttacked+03:
  jmp newmem
  nop 2
return:

[DISABLE]

healthWhenAttacked+03:
  db 48 8B 93 78 03 00 00

unregistersymbol(healthWhenAttacked)
registersymbol(*)
dealloc(newmem)

