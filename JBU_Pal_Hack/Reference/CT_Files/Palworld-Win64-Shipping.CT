      <AssemblerScript>{ Game   : Palworld-Win64-Shipping.exe
  Version:
  Date   : Probably somewhen, considering it exists
  Author : Byakuran

  This script injects code at the selected area
}
[ENABLE]

{$LUA}
if memrec then
  if memrec.Active then
    memrec.Active=false
  end
end

local moduleName = "Palworld-Win64-Shipping.exe"
local pattern = "48 8B 81 88 04 00 00 8B FA 48 8B D9 48 89 44 24 30 8B CF 48 8D 54 24 30 40 32 F6"
local name = "shieldSubtract"
local targetIndex = 1
local scanFlag = "*W+X"

-- Run setup
local success = setupPattern(pattern, name, targetIndex, moduleName, many)
if not success then error('AOB not found.') end
{$asm}
//aobscanmodule(shieldSubtract, Palworld-Win64-Shipping.exe, 48 8B 81 88 04 00 00)
alloc(newmem0,$1000,shieldSubtract)
label(code0)
label(return0)

newmem0:

xor edx,edx

code0:
  mov rax,[rcx+00000488]
  jmp return0

shieldSubtract:
  jmp newmem0
  nop 00000002
return0:

[DISABLE]

shieldSubtract:
  db 48 8B 81 88 04 00 00

unregistersymbol(shieldSubtract)
unregistersymbol(*)
dealloc(newmem0)


