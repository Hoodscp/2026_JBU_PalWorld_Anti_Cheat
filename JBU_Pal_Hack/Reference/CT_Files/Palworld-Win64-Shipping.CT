    <CheatEntry>
      <ID>54</ID>
      <Description>"Freeze Food Counters"</Description>
      <Options moHideChildren="1"/>
      <LastState/>
      <Color>00FF00</Color>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>{ Game   : Palworld-Win64-Shipping.exe
  Version: 
  Date   : 2024-12-24
  Author : krebs

  This script does blah blah blah
}

[ENABLE]
{$LUA}
if memrec then
  if memrec.Active then
    memrec.Active=false
  end
end

local moduleName = "Palworld-Win64-Shipping.exe"
local pattern = "F3 0F 11 83 58 01 00 00 E8"
local name = "foodTimerWrite"
local targetIndex = 1
local many = false

-- Run setup
setupPattern(pattern, name, targetIndex, moduleName, many)
{$asm}
//aobscanmodule(foodTimerWrite,Palworld-Win64-Shipping.exe,F3 0F 11 83 58 01 00 00 E8) // should be unique
alloc(newmem,$1000,foodTimerWrite)

label(code)
label(return)
label(smaller)

label(foodTimerWriteZeroSwtich)
registersymbol(foodTimerWriteZeroSwtich)

newmem:

cmp byte ptr [foodTimerWriteZeroSwtich],1
jne smaller

xorps xmm0,xmm0
jmp code

smaller:
minss xmm0,[rbx+00000158]

code:
  movss [rbx+00000158],xmm0
  jmp return

foodTimerWriteZeroSwtich:
db 0

foodTimerWrite:
  jmp newmem
  nop 3
return:


[DISABLE]

foodTimerWrite:
  db F3 0F 11 83 58 01 00 00

unregistersymbol(foodTimerWrite)
unregistersymbol(*)
dealloc(newmem)

