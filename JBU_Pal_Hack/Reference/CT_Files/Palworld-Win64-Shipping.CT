    <CheatEntry>
      <ID>2418</ID>
      <Description>"Teleport (only when dismounted)"</Description>
      <Options moHideChildren="1"/>
      <LastState/>
      <Color>F5F5F5</Color>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>{$LUA}
-- Position Saver Script
-- Saves, loads, and deletes coordinates from memory with configurable dimensions and data types

local NAME = "Position.Saver"
local VERSION = "2.0.0"
local DESCRIPTION = "Position Saver"

-- Configuration options
local CONFIG = {
    -- Set coordinate system (can be "2D" for X,Y or "3D" for X,Y,Z)
    dimensionType = "3D",
    -- Set data type (can be "float" or "double")
    dataType = "double",
    -- Base pointer name
    basePtrName = "basePtrPosXYZPtr",
    -- conversion of manually Input variables(read from map) to internal game-version
    coordinateConversion = 100,
    -- Number of address sets to modify (e.g., 1 for player only, 2 for head+torso, etc.)
    addressSetsCount = 1,
    -- Variable that represents height
    heightVar = "z",
    -- Value to add to the height on save to avoid in or below-ground spawn
    heightOffset = 0
}

-- Derived settings
local SETTINGS = {
    -- Size of each coordinate value in bytes (4 for float, 8 for double)
    valueSize = CONFIG.dataType == "double" and 8 or 4,
    -- Number of coordinates (2 for X,Y or 3 for X,Y,Z)
    dimensions = CONFIG.dimensionType == "2D" and 2 or 3,
    -- Function to read coordinate values (readFloat or readDouble)
    readValue = CONFIG.dataType == "double" and readDouble or readFloat,
    -- Function to write coordinate values (writeFloat or writeDouble)
    writeValue = CONFIG.dataType == "double" and writeDouble or writeFloat,
    -- Coordinate component names
    componentNames = CONFIG.dimensionType == "2D" and {"x", "y"} or {"x", "y", "z"}
}

-- UI Theme Colors
local COLOR_BG           = 0x2E2723
local COLOR_PANEL        = 0x3A312C
local COLOR_ACCENT       = 0x9CBC1A
local COLOR_TEXT         = 0xEAEAEA
local COLOR_LABEL        = 0xB0B0B0
local COLOR_BTN          = 0x2E2723
local COLOR_BTN_HOVER    = 0x9CBC1A
local COLOR_BTN_TEXT     = 0xEAEAEA
local COLOR_TAB_ACTIVE   = 0x9CBC1A
local COLOR_TAB_INACTIVE = 0x3A312C

local positionFile = "positions.dat"
local PositionManagerForm = nil

-- ============================================================================
-- UTILITY FUNCTIONS
-- ============================================================================

local function getCurrentAuthor()
    return os.getenv("USERNAME") or os.getenv("USER") or "Unknown"
end

-- ============================================================================
-- FILE I/O FUNCTIONS
-- ============================================================================


local function readTableFileContent(file)
    local stream = createStringStream()
    stream.copyFrom(file.Stream, file.Stream.Size)
    local lines = {}
    for line in string.gmatch(stream.DataString, "[^\r\n]+") do
        table.insert(lines, line)
    end
    stream.destroy()
    return lines
end

local function writeTableFileContent(file, content)
    file.Stream.Size = 0
    file.Stream.Position = 0
    if content and content ~= "" then
        file.Stream.write({string.byte(content, 1, #content)})
    end
end

-- ============================================================================
-- POSITION DATA FUNCTIONS
-- ============================================================================

local function loadPositions()
    local tf = findTableFile(positionFile)
    if not tf then
        tf = createTableFile(positionFile)
        if tf then
            writeTableFileContent(tf, "")
        else
            debugPrint("Failed to create position data file", 1)
        end
        return {}
    end

    local posData = {}
    local lines = readTableFileContent(tf)

    for _, line in ipairs(lines) do
        -- Try new format first: name|coords|author|category|description
        local name, coords, author, category, description = string.match(line, "([^|]+)|([^|]+)|([^|]*)|([^|]*)|([^|]*)")

        -- If new format parsing failed, try legacy format: name:x,y,z
        if not name or not coords then
            name, coords = string.match(line, "([^:]+):([%d%.%-%,]+)")
            if name and coords then
                -- Legacy format detected
                author = getCurrentAuthor()
                category = "Legacy"
                description = "Imported from old format"
            end
        end

        if name and coords then
            posData[name] = {
                points = {},
                Author = author ~= "" and author or getCurrentAuthor(),
                Category = category ~= "" and category or "Default",
                Description = description or ""
            }

            for coordPair in string.gmatch(coords, "([^;]+)") do
                local matches = {}
                for value in string.gmatch(coordPair, "([^,]+)") do
                    table.insert(matches, value)
                end

                if #matches == #SETTINGS.componentNames then
                    local point = {}
                    for i, component in ipairs(SETTINGS.componentNames) do
                        point[component] = tonumber(matches[i])
                    end
                    table.insert(posData[name].points, point)
                end
            end
        end
    end

    return posData
end

local function savePositionsToFile(positions)
    local tf = findTableFile(positionFile)
    if not tf then
        tf = createTableFile(positionFile)
        if not tf then
            debugPrint("Failed to create position file", 1)
            return false
        end
    end

    local lines = {}
    for name, data in pairs(positions) do
        local coordsStr = {}
        for _, point in ipairs(data.points) do
            local pointStr = {}
            for _, component in ipairs(SETTINGS.componentNames) do
                table.insert(pointStr, tostring(point[component]))
            end
            table.insert(coordsStr, table.concat(pointStr, ","))
        end

        local line = string.format("%s|%s|%s|%s|%s",
            name,
            table.concat(coordsStr, ";"),
            data.Author or getCurrentAuthor(),
            data.Category or "Default",
            data.Description or ""
        )
        table.insert(lines, line)
    end

    local content = table.concat(lines, "\n")
    local success, err = pcall(function()
        writeTableFileContent(tf, content)
    end)

    if not success then
        debugPrint("Error writing to file: " .. tostring(err), 1)
        return false
    end

    return true
end

-- ============================================================================
-- COORDINATE FUNCTIONS
-- ============================================================================

local function checkSymbolsExist()
    local hasBasePtr = getAddressSafe(CONFIG.basePtrName) ~= nil
    if not hasBasePtr then
        debugNotif("Required symbol '" .. CONFIG.basePtrName .. "' not found.\nEnsure the ASM portion is activated.", "Error", {"OK"}, nil, false, 1)
        return false
    end

    local basePtr = readQword(CONFIG.basePtrName)
    if basePtr == 0 then
        debugNotif("Position base pointer is invalid.\nMove in-game to populate values.", "Error", {"OK"}, nil, false, 1)
        return false
    end

    return true
end

local function getCurrentCoordinates()
    if not checkSymbolsExist() then
        return nil
    end

    local basePtr = readQword(CONFIG.basePtrName)
    if basePtr == 0 then
        return nil
    end

    local coords = {}
    for i, component in ipairs(SETTINGS.componentNames) do
        local offset = (i - 1) * SETTINGS.valueSize
        coords[component] = SETTINGS.readValue(basePtr + offset)
    end

    return coords
end

local function writeCoordinatesToMemory(coords)
    for setIndex = 0, CONFIG.addressSetsCount - 1 do
        local basePtr

        if setIndex == 0 then
            basePtr = readQword(CONFIG.basePtrName)
        else
            local basePtrAddress = getAddressSafe(CONFIG.basePtrName)
            if basePtrAddress == nil then
                return false
            end
            basePtr = readQword(basePtrAddress + (setIndex * 8))
        end

        if basePtr == 0 then
            return false
        end

        for i, component in ipairs(SETTINGS.componentNames) do
            local offset = (i - 1) * SETTINGS.valueSize
            SETTINGS.writeValue(basePtr + offset, coords[component])
        end
    end

    return true
end

-- ============================================================================
-- UI HELPER FUNCTIONS
-- ============================================================================

local function createDarkPanel(parent)
    local panel = createPanel(parent)
    panel.Color = COLOR_PANEL
    panel.BevelOuter = "bvNone"
    return panel
end

local function createStyledButton(parent, caption)
    local panel = createPanel(parent)
    panel.Align = "alTop"
    panel.Height = 30
    panel.BevelOuter = bvRaised
    panel.BevelWidth = 1
    panel.Color = COLOR_BTN
    panel.Cursor = -21
    panel.Caption = caption
    panel.BorderSpacing.Around = 3
    panel.Font.Color = COLOR_BTN_TEXT
    panel.Font.Name = "Consolas"
    panel.Font.Size = 10

    panel.OnMouseEnter = function()
        panel.Color = COLOR_BTN_HOVER
        panel.Font.Color = COLOR_BG
    end

    panel.OnMouseLeave = function()
        panel.Color = COLOR_BTN
        panel.Font.Color = COLOR_BTN_TEXT
    end

    return panel
end

local function createLabeledEdit(parent, labelText)
    local container = createDarkPanel(parent)
    container.Align = "alTop"
    container.Height = 28
    container.BorderSpacing.Around = 2

    local label = createLabel(container)
    label.Caption = labelText
    label.Align = "alLeft"
    label.Width = 100
    label.BorderSpacing.Around = 2
    label.Font.Color = COLOR_LABEL
    label.Font.Name = "Consolas"
    label.Font.Size = 10
    label.Layout = "tlCenter"

    local edit = createEdit(container)
    edit.Align = "alClient"
    edit.BorderSpacing.Around = 2
    edit.Color = COLOR_BG
    edit.Font.Color = COLOR_TEXT
    edit.Font.Name = "Consolas"
    edit.Font.Size = 10

    return edit
end

-- ============================================================================
-- TREE VIEW FUNCTIONS
-- ============================================================================

local function loadPositionsToTreeView(treeView, searchQuery)
    treeView.beginUpdate()
    treeView.Items:clear()

    local positions = loadPositions()
    if not positions or not next(positions) then
        treeView.endUpdate()
        return
    end

    searchQuery = searchQuery or ""

    -- Group by author and category
    local grouped = {}
    for name, data in pairs(positions) do
        local author = data.Author or "Unknown"
        local category = data.Category or "Default"

        -- Apply search filter
        if searchQuery == "" or
           name:lower():find(searchQuery:lower()) or
           author:lower():find(searchQuery:lower()) or
           category:lower():find(searchQuery:lower()) then

            grouped[author] = grouped[author] or {}
            grouped[author][category] = grouped[author][category] or {}
            table.insert(grouped[author][category], name)
        end
    end

    -- Build tree
    local sortedAuthors = {}
    for author in pairs(grouped) do
        table.insert(sortedAuthors, author)
    end
    table.sort(sortedAuthors, function(a, b) return a:lower() &lt; b:lower() end)

    for _, author in ipairs(sortedAuthors) do
        local authorNode = treeView.Items:add()
        authorNode.Text = author

        local sortedCategories = {}
        for category in pairs(grouped[author]) do
            table.insert(sortedCategories, category)
        end
        table.sort(sortedCategories, function(a, b) return a:lower() &lt; b:lower() end)

        for _, category in ipairs(sortedCategories) do
            local categoryNode = authorNode:add()
            categoryNode.Text = category

            local saves = grouped[author][category]
            table.sort(saves, function(a, b) return a:lower() &lt; b:lower() end)

            for _, saveName in ipairs(saves) do
                local saveNode = categoryNode:add()
                saveNode.Text = saveName
            end
        end
    end

    treeView.endUpdate()
end

-- ============================================================================
-- POSITION OPERATIONS
-- ============================================================================

local function addPosition(name, coords, author, category, description, isNewPoint)
    if not name or name == "" then
        debugPrint("Invalid position name", 1)
        return false
    end

    if not coords or type(coords) ~= "table" then
        debugPrint("Invalid coordinates", 1)
        return false
    end

    local positions = loadPositions()

    if positions[name] and not isNewPoint then
        -- Overwrite existing position
        positions[name].points = {coords}
        positions[name].Author = author or getCurrentAuthor()
        positions[name].Category = category or "Default"
        positions[name].Description = description or ""
    elseif positions[name] and isNewPoint then
        -- Add point to existing position
        table.insert(positions[name].points, coords)
    else
        -- Create new position
        positions[name] = {
            points = {coords},
            Author = author or getCurrentAuthor(),
            Category = category or "Default",
            Description = description or ""
        }
    end

    return savePositionsToFile(positions)
end

local function deletePosition(name, pointIndex)
    local positions = loadPositions()

    if not positions[name] then
        debugPrint("Position not found: " .. name, 2)
        return false
    end

    if pointIndex and pointIndex &gt; 0 and pointIndex &lt;= #positions[name].points then
        -- Delete specific point
        table.remove(positions[name].points, pointIndex)

        -- If no points left, delete entire position
        if #positions[name].points == 0 then
            positions[name] = nil
        end
    else
        -- Delete entire position
        positions[name] = nil
    end

    return savePositionsToFile(positions)
end

local function updatePosition(oldName, newName, coords, author, category, description)
    local positions = loadPositions()

    if not positions[oldName] then
        debugPrint("Position not found: " .. oldName, 1)
        return false
    end

    -- Update data
    local data = positions[oldName]
    data.points = {coords}
    data.Author = author or data.Author
    data.Category = category or data.Category
    data.Description = description or data.Description

    -- Handle rename
    if oldName ~= newName then
        positions[newName] = data
        positions[oldName] = nil
    end

    return savePositionsToFile(positions)
end

local function loadPositionToGame(name, pointIndex)
    if not checkSymbolsExist() then
        return false
    end

    local positions = loadPositions()
    local posData = positions[name]

    if not posData or not posData.points or #posData.points == 0 then
        debugPrint("Position not found or empty: " .. name, 1)
        return false
    end

    pointIndex = pointIndex or 1
    local coords = posData.points[pointIndex]

    if not coords then
        debugPrint("Point index out of range", 1)
        return false
    end

    local success = writeCoordinatesToMemory(coords)

    if success then
        local coordStr = ""
        for _, comp in ipairs(SETTINGS.componentNames) do
            coordStr = coordStr .. string.format("%s: %.2f ", comp:upper(), coords[comp])
        end
        debugPrint("Loaded position '" .. name .. "' (point " .. pointIndex .. "): " .. coordStr, 2)
    end

    return success
end

-- ============================================================================
-- MAIN UI CREATION
-- ============================================================================

local function createTabControl(parent)
    local tabButtonPanel = createDarkPanel(parent)
    tabButtonPanel.Align = "alTop"
    tabButtonPanel.Height = 30
    tabButtonPanel.BorderSpacing.Around = 4

    local tabContentPanel = createDarkPanel(parent)
    tabContentPanel.Align = "alClient"
    tabContentPanel.BorderSpacing.Around = 4

    local tabs = {
        {caption = "Details", page = nil},
        {caption = "Coordinates", page = nil},
        {caption = "Description", page = nil}
    }

    local tabPanels = {}

    -- Create tab pages
    for i, tab in ipairs(tabs) do
        local page = createDarkPanel(tabContentPanel)
        page.Align = "alClient"
        page.Visible = (i == 1)
        tabs[i].page = page
    end

    -- Select tab function
    local function selectTab(idx)
        for i, tab in ipairs(tabs) do
            tab.page.Visible = (i == idx)
            if tabPanels[i] then
                tabPanels[i].Color = (i == idx) and COLOR_TAB_ACTIVE or COLOR_TAB_INACTIVE
                tabPanels[i].Font.Color = (i == idx) and COLOR_BG or COLOR_TEXT
            end
        end
    end

    -- Create tab buttons
    for i, tab in ipairs(tabs) do
        local p = createDarkPanel(tabButtonPanel)
        p.Left = (i-1) * 145
        p.Top = 2
        p.Width = 140
        p.Height = 26
        p.BevelOuter = bvRaised
        p.BevelWidth = 1
        p.Caption = tab.caption
        p.Font.Name = "Consolas"
        p.Font.Size = 10
        p.Color = COLOR_TAB_INACTIVE
        p.Font.Color = COLOR_TEXT
        p.ParentFont = false
        p.Cursor = -21

        p.OnClick = function()
            selectTab(i)
        end

        p.OnMouseEnter = function()
            if tabs[i].page.Visible then return end
            p.Color = COLOR_ACCENT
            p.Font.Color = COLOR_BG
        end

        p.OnMouseLeave = function()
            if tabs[i].page.Visible then return end
            p.Color = COLOR_TAB_INACTIVE
            p.Font.Color = COLOR_TEXT
        end

        tabPanels[i] = p
    end

    selectTab(1)

    return tabButtonPanel, tabContentPanel, tabs
end

local function createDetailsPanel(parent)
    local panel = createDarkPanel(parent)
    panel.Align = "alClient"
    panel.BorderSpacing.Around = 5

    local nameEdit = createLabeledEdit(panel, "Name:")
    nameEdit.TextHint = "Position Name"

    local authorEdit = createLabeledEdit(panel, "Author:")
    authorEdit.TextHint = "Position Author"

    local categoryEdit = createLabeledEdit(panel, "Category:")
    categoryEdit.TextHint = "Position Category"

    return nameEdit, authorEdit, categoryEdit
end

local function createCoordinatesPanel(parent)
    local panel = createDarkPanel(parent)
    panel.Align = "alClient"
    panel.BorderSpacing.Around = 5

    local edits = {}
    for i = #SETTINGS.componentNames, 1, -1 do
        local component = SETTINGS.componentNames[i]
        local edit = createLabeledEdit(panel, component:upper() .. ":")
        edit.TextHint = component:upper() .. " Coordinate"
        edits[component] = edit
    end

    return edits
end

local function createDescriptionPanel(parent)
    local panel = createDarkPanel(parent)
    panel.Align = "alClient"
    panel.BorderSpacing.Around = 5

    local memo = createMemo(panel)
    memo.Align = "alClient"
    memo.BorderSpacing.Around = 5
    memo.TextHint = "Description (optional)"
    memo.Color = COLOR_BG
    memo.Font.Color = COLOR_TEXT
    memo.Font.Name = "Consolas"
    memo.Font.Size = 10
    memo.WordWrap = true
    memo.ScrollBars = "ssAutoBoth"

    return memo
end

local function createTreeViewPanel(parent)
    local panel = createDarkPanel(parent)
    panel.Align = "alTop"
    panel.Height = 350
    panel.BorderSpacing.Around = 3

    local searchEdit = createEdit(panel)
    searchEdit.Align = "alTop"
    searchEdit.Height = 30
    searchEdit.BorderSpacing.Around = 3
    searchEdit.TextHint = "Search Positions..."
    searchEdit.Color = COLOR_BG
    searchEdit.Font.Color = COLOR_TEXT
    searchEdit.Font.Name = "Consolas"
    searchEdit.Font.Size = 10

    local treeView = createTreeView(panel)
    treeView.Align = "alClient"
    treeView.BorderSpacing.Around = 3
    treeView.AutoExpand = true
    treeView.ReadOnly = true
    treeView.BorderStyle = "bsNone"
    treeView.Color = COLOR_PANEL
    treeView.Font.Color = COLOR_TEXT
    treeView.Font.Name = "Consolas"
    treeView.Font.Size = 10
    treeView.ScrollBars = "ssAutoBoth"

    return panel, searchEdit, treeView
end

local function createContextMenu(treeView, ui)
    local menu = createPopupMenu(treeView)
    treeView.PopupMenu = menu

    local teleportItem = createMenuItem(menu)
    teleportItem.Caption = "Teleport To Position"
    teleportItem.OnClick = function()
        local selected = treeView.Selected
        if not selected or selected.Level ~= 2 then return end

        local saveName = selected.Text
        local positions = loadPositions()
        local posData = positions[saveName]

        if not posData then return end

        if #posData.points &gt; 1 then
            -- Show point selection dialog
            local pointIdx = 1 -- For now, use first point
            if loadPositionToGame(saveName, pointIdx) then
                debugNotif("Teleported to '" .. saveName .. "'!", "Success", {"OK"}, nil, false, 2)
            else
                debugNotif("Failed to teleport to position.", "Error", {"OK"}, nil, false, 1)
            end
        else
            if loadPositionToGame(saveName, 1) then
                debugNotif("Teleported to '" .. saveName .. "'!", "Success", {"OK"}, nil, false, 2)
            else
                debugNotif("Failed to teleport to position.", "Error", {"OK"}, nil, false, 1)
            end
        end
    end
    menu.Items.add(teleportItem)

    local sep1 = createMenuItem(menu)
    sep1.Caption = "-"
    menu.Items.add(sep1)

    local deleteItem = createMenuItem(menu)
    deleteItem.Caption = "Delete Position"
    deleteItem.OnClick = function()
        local selected = treeView.Selected
        if not selected or selected.Level ~= 2 then return end

        local saveName = selected.Text

        notification(
            "Delete '" .. saveName .. "'?",
            "Confirm Delete",
            {"Yes", "No"},
            function(buttonClicked)
                if buttonClicked == "Yes" then
                    if deletePosition(saveName) then
                        debugNotif("Position '" .. saveName .. "' deleted successfully.", "Success", {"OK"}, nil, false, 2)
                        loadPositionsToTreeView(treeView)
                        ui.nameEdit.Text = ""
                        ui.authorEdit.Text = ""
                        ui.categoryEdit.Text = ""
                        for _, edit in pairs(ui.coordEdits) do
                            edit.Text = ""
                        end
                        ui.descriptionMemo.Lines.Text = ""
                    else
                        debugNotif("Failed to delete position.", "Error", {"OK"}, nil, false, 1)
                    end
                end
            end
        )
    end
    menu.Items.add(deleteItem)

    return menu
end

function createPositionManagerUI()
    if PositionManagerForm then
        PositionManagerForm.show()
        PositionManagerForm.BringToFront()
        return
    end

    local form = createForm(false)
    form.Caption = "Position Manager v" .. VERSION
    form.Width = 750
    form.Height = 650
    form.Color = COLOR_BG
    form.Font.Name = "Consolas"
    form.Font.Size = 10
    form.Font.Color = COLOR_TEXT
    form.Position = "poScreenCenter"
    form.BorderStyle = "bsSizeable"
    form.Constraints.MinWidth = 700
    form.Constraints.MinHeight = 600

    PositionManagerForm = form

    -- Create main container
    local mainPanel = createDarkPanel(form)
    mainPanel.Align = "alClient"

    -- Create tree view panel at top
    local treePanel, searchEdit, treeView = createTreeViewPanel(mainPanel)

    -- Create details panel at bottom
    local detailsContainer = createDarkPanel(mainPanel)
    detailsContainer.Align = "alClient"
    detailsContainer.BorderSpacing.Around = 3

    -- Create tab control
    local tabButtonPanel, tabContentPanel, tabs = createTabControl(detailsContainer)

    -- Create tab contents
    local nameEdit, authorEdit, categoryEdit = createDetailsPanel(tabs[1].page)
    local coordEdits = createCoordinatesPanel(tabs[2].page)
    local descriptionMemo = createDescriptionPanel(tabs[3].page)

    -- Create button panel at bottom
    local buttonPanel = createDarkPanel(detailsContainer)
    buttonPanel.Align = "alBottom"
    buttonPanel.Height = 140
    buttonPanel.BorderSpacing.Around = 5

    local btnLoadCurrent = createStyledButton(buttonPanel, "Load Current Position")
    local btnSaveCurrent = createStyledButton(buttonPanel, "Save Current Position")
    local btnUpdate = createStyledButton(buttonPanel, "Update Position")
    local btnTeleport = createStyledButton(buttonPanel, "Teleport To Position")

    -- Store UI references
    local ui = {
        form = form,
        treeView = treeView,
        searchEdit = searchEdit,
        nameEdit = nameEdit,
        authorEdit = authorEdit,
        categoryEdit = categoryEdit,
        coordEdits = coordEdits,
        descriptionMemo = descriptionMemo,
        btnLoadCurrent = btnLoadCurrent,
        btnSaveCurrent = btnSaveCurrent,
        btnUpdate = btnUpdate,
        btnTeleport = btnTeleport
    }

    -- Create context menu
    createContextMenu(treeView, ui)

    -- Set up event handlers
    searchEdit.OnChange = function()
        loadPositionsToTreeView(treeView, searchEdit.Text)
    end

    treeView.OnClick = function()
        local selected = treeView.Selected
        if not selected or selected.Level ~= 2 then return end

        local saveName = selected.Text
        local positions = loadPositions()
        local posData = positions[saveName]

        if not posData then return end

        nameEdit.Text = saveName
        authorEdit.Text = posData.Author or ""
        categoryEdit.Text = posData.Category or ""
        descriptionMemo.Lines.Text = posData.Description or ""

        -- Load first point coordinates
        if #posData.points &gt; 0 then
            local point = posData.points[1]
            for comp, edit in pairs(coordEdits) do
                edit.Text = tostring(point[comp] or 0)
            end
        end
    end

    treeView.OnDblClick = function()
        local selected = treeView.Selected
        if not selected or selected.Level ~= 2 then return end

        local saveName = selected.Text
        if loadPositionToGame(saveName, 1) then
            debugNotif("Teleported to '" .. saveName .. "'!", "Success", {"OK"}, nil, false, 2)
        else
            debugNotif("Failed to teleport to position.", "Error", {"OK"}, nil, false, 1)
        end
    end

    btnLoadCurrent.OnClick = function()
        local coords = getCurrentCoordinates()
        if not coords then
            debugNotif("Unable to read current coordinates.\nMake sure you're in-game and have moved.", "Error", {"OK"}, nil, false, 1)
            return
        end

        -- Populate coordinate fields with current position
        for comp, edit in pairs(coordEdits) do
            if coords[comp] then
                edit.Text = string.format("%.8f", coords[comp])
            end
        end

        -- Show success message
        local coordStr = ""
        for _, comp in ipairs(SETTINGS.componentNames) do
            coordStr = coordStr .. string.format("%s: %.2f ", comp:upper(), coords[comp])
        end
        debugPrint("Loaded current position: " .. coordStr, 2)
        debugNotif("Current position loaded into coordinate fields!", "Success", {"OK"}, nil, false, 2)
    end

    btnSaveCurrent.OnClick = function()
        local coords = getCurrentCoordinates()
        if not coords then
            debugNotif("Unable to read current coordinates.\nMake sure you're in-game and have moved.", "Error", {"OK"}, nil, false, 1)
            return
        end

        -- Add height offset
        if coords[CONFIG.heightVar] then
            coords[CONFIG.heightVar] = coords[CONFIG.heightVar] + CONFIG.heightOffset
        end

        local name = nameEdit.Text
        if name == "" then
            debugNotif("Please enter a position name.", "Warning", {"OK"}, nil, false, 1)
            return
        end

        local author = authorEdit.Text ~= "" and authorEdit.Text or getCurrentAuthor()
        local category = categoryEdit.Text ~= "" and categoryEdit.Text or "Default"
        local description = descriptionMemo.Lines.Text

        if addPosition(name, coords, author, category, description, false) then
            debugNotif("Position '" .. name .. "' saved successfully!", "Success", {"OK"}, nil, false, 2)
            loadPositionsToTreeView(treeView, searchEdit.Text)
        else
            debugNotif("Failed to save position.", "Error", {"OK"}, nil, false, 1)
        end
    end

    btnUpdate.OnClick = function()
        local selected = treeView.Selected
        if not selected or selected.Level ~= 2 then
            debugNotif("Please select a position from the tree.", "Warning", {"OK"}, nil, false, 1)
            return
        end

        local oldName = selected.Text
        local newName = nameEdit.Text

        if newName == "" then
            debugNotif("Position name cannot be empty.", "Warning", {"OK"}, nil, false, 1)
            return
        end

        local coords = {}
        for comp, edit in pairs(coordEdits) do
            coords[comp] = tonumber(edit.Text)
            if not coords[comp] then
                debugNotif("Invalid coordinate value for " .. comp:upper(), "Error", {"OK"}, nil, false, 1)
                return
            end
        end

        local author = authorEdit.Text ~= "" and authorEdit.Text or getCurrentAuthor()
        local category = categoryEdit.Text ~= "" and categoryEdit.Text or "Default"
        local description = descriptionMemo.Lines.Text

        if updatePosition(oldName, newName, coords, author, category, description) then
            debugNotif("Position updated successfully!", "Success", {"OK"}, nil, false, 2)
            loadPositionsToTreeView(treeView, searchEdit.Text)
        end
    end

    btnTeleport.OnClick = function()
        local name = nameEdit.Text
        if name == "" then
            debugNotif("Please select or enter a position name.", "Warning", {"OK"}, nil, false, 1)
            return
        end

        if loadPositionToGame(name, 1) then
            debugNotif("Position updated successfully!", "Success", {"OK"}, nil, false, 2)
        else
            debugNotif("Failed to update position.", "Error", {"OK"}, nil, false, 1)
        end
    end

    form.OnClose = function()
        PositionManagerForm = nil
        return caFree
    end

    -- Load initial data
    loadPositionsToTreeView(treeView)

    form.show()
end

-- ============================================================================
-- LEGACY COMPATIBILITY (Optional)
-- ============================================================================

function showPositionMenu()
    createPositionManagerUI()
end

