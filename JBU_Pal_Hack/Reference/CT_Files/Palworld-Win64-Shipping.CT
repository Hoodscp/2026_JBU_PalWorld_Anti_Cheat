    <CheatEntry>
      <ID>1337369017</ID>
      <Description>"Activate Favourites"</Description>
      <LastState/>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>{$LUA}
if syntaxcheck then return end

[ENABLE]
-- Define the list of cheats to activate
local cheats = {
    'Shield Does Not Decrease',
    'Damage/Health',
    'Infinite Stamina',
    {id = 1337369788, name = 'Infinite Ammo'},
    'Inf Sphere',
    'Inf Pal Ability Ammo(example: Jetdragon rocket)',
    'High Capture',
    'Guarantee Capture',
    'Can Capture Everything(Bosses, Arena Merchant)',
    'New Spawns Have Perfect Stats',
    'Never Get Hungry',
    'Max Sanity',
    'Zero Weight',
    'Instant Fishing',
    'Inf Durability',
    'Freeze Food Counters'
}

-- Loop through each cheat and activate with 100ms delay
for i, cheat in ipairs(cheats) do
    if type(cheat) == "table" then
        -- Use ID-based access
        AddressList.getMemoryRecordByID(cheat.id).Active = true
    else
        -- Use name-based access
        AddressList[cheat].Active = true
    end
    sleep(100)  -- 100ms delay
end

[DISABLE]
-- Loop through each cheat and deactivate

--[[
for i, cheat in ipairs(cheats) do
    AddressList[cheat].Active = false
end

--]]
</AssemblerScript>
