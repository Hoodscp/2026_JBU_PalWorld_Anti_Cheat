        <CheatEntry>
          <ID>1138</ID>
          <Description>"Stack Count"</Description>
          <ShowAsSigned>1</ShowAsSigned>
          <Color>00FF00</Color>
          <VariableType>4 Bytes</VariableType>
          <Address>takeStackSaveSpace</Address>
        </CheatEntry>
        <CheatEntry>
          <ID>1139</ID>
          <Description>"Permanently Change Count"</Description>
          <LastState/>
          <Color>00FF00</Color>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>[ENABLE]
//code from here to '[DISABLE]' will be used to enable the cheat

{$lua}

if syntaxcheck then return end

local function writeNewValue(number)
  local baseAddress = getAddress('takeStackSaveSpace')
  if not baseAddress then
      return
  else
      writeSmallInteger(baseAddress, number)
  end
end

local parent = memrec.Parent

if parent then
   -- Show input dialog for new value
   local newValue = inputQuery("Change Value", "Enter new value:", "1")

   if newValue then
       -- Validate input is a number
       local number = tonumber(newValue)
       if number then
           local parentScript = parent.Script
           if parentScript then
               local found = false

               -- First check for pattern with newline with any whitespace after takeStackSaveSpace:
               if parentScript:match("takeStackSaveSpace:\r?\n%s*dd%s+%d+") then
                   local newScript = parentScript:gsub("(takeStackSaveSpace:\r?\n%s*dd%s+)(%d+)", "%1" .. newValue)
                   parent.Script = newScript
                   found = true
                   showMessage("Changed value in parent script.")
                   if parent.Active then
                      writeNewValue(number)
                   end

               -- If not found, check for same-line pattern
               elseif parentScript:match("takeStackSaveSpace:%s*dd%s+%d+") then
                   local newScript = parentScript:gsub("(takeStackSaveSpace:%s*dd%s+)(%d+)", "%1" .. newValue)
                   parent.Script = newScript
                   found = true
                   showMessage("Changed value in parent script.")
                   if parent.Active then
                      writeNewValue(number)
                   end
               end

               if not found then
                   showMessage("Could not find 'takeStackSaveSpace: dd' pattern in parent script:\n\n" .. parentScript)
               end
           else
               showMessage("Parent has no script content")
           end
       else
           showMessage("Please enter a valid number")
       end
   end
else
   showMessage("Parent not found")
end

{$asm}


{$lua}
if syntaxcheck then return end

local t=createTimer()
t.Interval=50
t.OnTimer=function()
  memrec.Active=false
  t.destroy()
end

{$asm}


[DISABLE]
//code from here till the end of the code will be used to disable the cheat
</AssemblerScript>
        </CheatEntry>
      </CheatEntries>
