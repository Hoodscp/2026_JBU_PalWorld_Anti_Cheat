    <CheatEntry>
      <ID>1337369818</ID>
      <Description>"Damage/Health"</Description>
      <Options moHideChildren="1" moDeactivateChildrenAsWell="1"/>
      <LastState/>
      <Color>0000FF</Color>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>{ Game   : Palworld-Win64-Shipping.exe
  Version: 
  Date   : 2025-03-19
  Author : krebs

  This script does blah blah blah
}

[ENABLE]
{$lua}

if memrec.Active then
   memrec.Active=false
end

local moduleName = "Palworld-Win64-Shipping.exe"
local pattern = "48 8B 80 00 04 00 00 48 89 44 24 20 45 8B C7 48 8D 54 24 20 48 8D 4D 9F"
local name = "mobsTakeDamgBossF"
local targetIndex = 1
local scanFlag = "*W+X"

-- Run setup
local success = setupPattern(pattern, name, targetIndex, moduleName, many)
if not success then error('AOB not found.') end

local toEnable = {"Take No Damage", "Max Out Health"}
local t=createTimer()
t.Interval=50
t.OnTimer=function()
  if memrec.Active then
    enableChildren(toEnable, memrec)
  end
  t.destroy()
end

{$asm}
//aobscanmodule(mobsTakeDamgBossF,Palworld-Win64-Shipping.exe,48 8B 80 88 03 00 00 48 89 45 58 45 8B C4) // should be unique
alloc(newmem0,$1000,mobsTakeDamgBossF)

label(code0)
label(return0)

label(mobsTakeDamgBossFSaveSpace)
registersymbol(mobsTakeDamgBossFSaveSpace)
label(player)
label(enemy)

newmem0:

/*rax
offset ally entity
60     1    0
64     4    0
430    0    100000
654    1    0
*/

/* old
offset  ally  enemy
40      1     2
60      1     0
64      4     0
A4      4     0
E0      1     0

/* old
offset  ally  enemy
30      6     3    //nope
64      4     0
1F0     0     2
260     1     0    //also has trainer ones
3DC     1     0
*/

push rax
mov rax,[rax+00000400]
mov [mobsTakeDamgBossFSaveSpace+9],rax
pop rax

cmp dword ptr [rax+60],1
jne enemy
player:
mov [mobsTakeDamgBossFSaveSpace+1],rax
  bt [mobsTakeDamgBossFSaveSpace],0       //Max out health
  jnc @f
    push rax
    mov eax,[rax+000005F8]
    mov [mobsTakeDamgBossFSaveSpace+9],rax
    pop rax
  @@:
  bt [mobsTakeDamgBossFSaveSpace],1       //Take no Damage
  jnc @f
    xor r15d,r15d
  @@:
  jmp code0
enemy:
  bt [mobsTakeDamgBossFSaveSpace],2 //OHK
  jnc @f
    push rax
    xor rax,rax
    mov [mobsTakeDamgBossFSaveSpace+9],rax
    pop rax
  @@:
  bt [mobsTakeDamgBossFSaveSpace],3 //Immortal Enemy
  jnc @f
    xor r15d,r15d
  @@:
  bt [mobsTakeDamgBossFSaveSpace],4 //almosstDead
  jnc @f
  push rax
  push rcx
  push rdx

  mov r15d,[mobsTakeDamgBossFSaveSpace+9]
  dec r15d
  mov eax,r15d
  mov ecx,#1000
  xor edx,edx
  div ecx
  mov r15d,eax

  pop rdx
  pop rcx
  pop rax

  @@:
  jmp code0

code0:
mov rax,[mobsTakeDamgBossFSaveSpace+9]
  //mov rax,[rax+000003F0]
  jmp return0
 
mobsTakeDamgBossFSaveSpace:
db 0                    //Cheat flags: bit 0=Max Out Health, bit 1=Take no Damage, bit 2=OHK, bit 3=Immortal Enemy
dq 0                    //pointer to player     +4
dq 0                    //healthHolder

mobsTakeDamgBossF:
  jmp newmem0
  nop 2
return0:

[DISABLE]

mobsTakeDamgBossF:
  db 48 8B 80 00 04 00 00

unregistersymbol(mobsTakeDamgBossF)
unregistersymbol(*)
dealloc(newmem0)

