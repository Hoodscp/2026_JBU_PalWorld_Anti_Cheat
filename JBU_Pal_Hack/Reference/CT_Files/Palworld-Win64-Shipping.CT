[ENABLE]
{$LUA}
if syntaxcheck then return end
local function parseInstructionDetails(name)
  local address = getAddress(name)
  local info = disassemble(address)
  local _, opcode, bytes, extra = splitDisassembledString(info)
  local instruction = opcode:match("^(%S+)")

  -- Extract operands by splitting on comma first
  local operands = {}
  for operand in opcode:gmatch("[^,]+") do
    operands[#operands + 1] = operand:match("%S+$") -- Get last word (the operand part)
  end

  local reg1, reg2, offset

  -- Parse first operand
  if operands[1] then
    local firstOp = operands[1]:gsub("^%S+%s+", "") -- Remove instruction name
    if firstOp:match("%[") then
      -- Memory operand like [rsp+1C] or [r12+20]
      reg1 = firstOp:match("%[([a-z0-9]+)")
      offset = firstOp:match("%+([%x]+)%]")
    else
      -- Register operand
      reg1 = firstOp
    end
  end

  -- Parse second operand
  if operands[2] then
    local secondOp = operands[2]:gsub("^%s+", "") -- Remove leading whitespace
    if secondOp:match("%[") then
      -- Memory operand like [rbp+10]
      reg2 = secondOp:match("%[([a-z0-9]+)")
      if not offset then -- Only set offset if not already set from first operand
        offset = secondOp:match("%+([%x]+)%]")
      end
    else
      -- Register operand
      reg2 = secondOp
    end
  end

  return instruction, reg1, reg2, offset
end


